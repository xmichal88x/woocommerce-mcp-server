# WooCommerce Connection
WOOCOMMERCE_URL=https://your-store.com
WOOCOMMERCE_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxx
WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxx

# Tool Group Configuration (comma-separated list of enabled groups)
# Available: products, orders, customers, coupons, shipping, taxes, reports, system, email, configurator, panel, media
# Use "all" to enable everything
WC_TOOL_GROUPS=all

# Panel Configurator Bridge API Secret (required for configurator + panel tools)
PCB_API_SECRET=

# WordPress Application Password (required for media tools)
# Generate in WP Admin → Users → Profile → Application Passwords
WP_APP_USERNAME=
WP_APP_PASSWORD=

# Security
WC_READ_ONLY=false

# Server
WC_TIMEOUT_MS=15000
WC_RETRY_COUNT=3

# SSRF Protection (optional comma-separated allowed domains)
# WC_ALLOWED_DOMAINS=your-store.com,another-store.com
